<?xml version="1.0" encoding="utf-8"?>
<!--
  overlay_panel.xml
  The compose panel that floats above the button when tapped.
  Contains: recipient picker, message input, encrypt + copy button.
  All crypto logic is in JS (CryptoBridge); this is just the shell.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/panel_background"
    android:elevation="16dp"
    android:padding="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="8dp"
        android:background="@drawable/panel_header_bg">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_lock"
            android:alpha="0.8" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Encrypt message"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#1A1625" />

        <ImageButton
            android:id="@+id/panel_close"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            android:contentDescription="Close"
            android:padding="8dp"
            android:tint="#9490AE" />
    </LinearLayout>

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#1A6C4FF0" />

    <!-- Recipient row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <Spinner
            android:id="@+id/recipient_spinner"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/spinner_background"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="13sp" />

        <ToggleButton
            android:id="@+id/toggle_group"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:textOn="Group"
            android:textOff="1:1"
            android:textSize="11sp"
            android:background="@drawable/toggle_background"
            android:paddingStart="10dp"
            android:paddingEnd="10dp" />
    </LinearLayout>

    <!-- Message input -->
    <EditText
        android:id="@+id/message_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:maxLines="4"
        android:scrollbars="vertical"
        android:gravity="top"
        android:background="@null"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:hint="Type your private message…"
        android:hintTextColor="#9490AE"
        android:textSize="15sp"
        android:textColor="#1A1625"
        android:inputType="textMultiLine|textCapSentences" />

    <!-- Status text (shown briefly after encrypt) -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="2dp"
        android:textSize="11sp"
        android:visibility="gone" />

    <!-- Divider -->
    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#0F6C4FF0" />

    <!-- Footer: algo tag + send button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔒 AES-256-GCM · ECDH"
            android:textSize="10sp"
            android:textColor="#726C4FF0"
            android:alpha="0.7" />

        <Button
            android:id="@+id/btn_encrypt"
            android:layout_width="wrap_content"
            android:layout_height="34dp"
            android:text="Encrypt &amp; copy"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6C4FF0"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:enabled="false" />
    </LinearLayout>

</LinearLayout>
